#!/usr/bin/env bash

set -euo pipefail


BASE_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && cd .. && pwd )"
source "$BASE_DIR/.env"

APP_NAME=${APP_NAME:-"Server"}
LOCKFILE="$BASE_DIR/.deploy.lock"
LOGFILE="$BASE_DIR/logs/worker-$(date -u +"%Y-%m-%d").log"
REDIS_CLI="redis-cli -u $REDIS_URL"
QUEUE=${REDIS_QUEUE:-deploy:queue}
DEPLOY_TIMEOUT=${DEPLOY_TIMEOUT:-600}

mkdir -p "$BASE_DIR/logs"

exec 200>"$LOCKFILE"
flock -n 200 || exit 0

log() {
  echo "$(date -u +"%Y-%m-%dT%H:%M:%SZ") $*" >>"$LOGFILE"
  echo "$*"
}

notify() {
  local message="$1"
  shift
  local notify_cmd="$BASE_DIR/bin/notify"

  if [[ -z "${TELEGRAM_CHAT_ID:-}" ]]; then
    log "Skipping notification (missing TELEGRAM_CHAT_ID): $message"
    return 0
  fi

  if [[ ! -x "$notify_cmd" ]]; then
    log "Skipping notification (notify not found): $message"
    return 0
  fi

  nohup "$notify_cmd" "$TELEGRAM_CHAT_ID" "$message" "$@" >/dev/null 2>&1 &
}

shutdown() {
  log "Received shutdown signal, exiting"
  exit 0
}

trap shutdown SIGINT SIGTERM

sanitize_for_filename() {
  local value="$1"
  value="${value//\//-}"
  value="${value//[^A-Za-z0-9._-]/-}"
  echo "$value"
}

while true; do
  payload="$($REDIS_CLI LPOP "$QUEUE")" || true
  if [[ -z "$payload" ]]; then
    sleep 1
    continue
  fi

  repo=$(jq -r '.repository // empty' <<<"$payload")
  branch=$(jq -r '.branch // empty' <<<"$payload")
  commit=$(jq -r '.commit // empty' <<<"$payload")

  if [[ -z "$repo" || -z "$branch" || -z "$commit" ]]; then
    log "Invalid JSON payload: $payload"
    continue
  fi

  safe_branch="$(sanitize_for_filename "$branch")"
  safe_commit="$(sanitize_for_filename "$commit")"
  DEPLOY_LOG="$BASE_DIR/logs/deploy-$safe_branch-$safe_commit.log"

  log "Deploying $repo $branch $commit"
  log "Deploy log: $DEPLOY_LOG"
  notify "📦 [$APP_NAME] Starting deploy: $repo $branch $commit"

  set +e
  timeout "$DEPLOY_TIMEOUT" "$BASE_DIR/bin/deploy" "$repo" "$branch" "$commit" 2>&1 \
    | sed -r 's/\x1B\[[0-9;]*[[:alpha:]]//g' >>"$DEPLOY_LOG"
  status=${PIPESTATUS[0]}
  set -e

  if [[ $status -eq 0 ]]; then
    log "Deploy success for $repo@$commit"
    notify "✅ [$APP_NAME] Deploy success: $repo $branch $commit" --file $DEPLOY_LOG
  elif [[ $status -eq 124 ]]; then
    log "Deploy timed out for $repo@$commit (exceeded ${DEPLOY_TIMEOUT}s)"
    if [[ -s "$DEPLOY_LOG" ]]; then
      log "Last 200 lines from $DEPLOY_LOG:"
      tail -n 200 "$DEPLOY_LOG" | while IFS= read -r line; do
        log "  $line"
      done
    fi
    notify "⏰ [$APP_NAME] Deploy timed out: $repo $branch $commit" --file $DEPLOY_LOG
  else
    log "Deploy failed for $repo@$commit (exit $status)"
    if [[ -s "$DEPLOY_LOG" ]]; then
      log "Last 200 lines from $DEPLOY_LOG:"
      tail -n 200 "$DEPLOY_LOG" | while IFS= read -r line; do
        log "  $line"
      done
    else
      log "Deploy log is empty; check worker stdout/stderr for earlier errors."
    fi
    notify "❌ [$APP_NAME] Deploy failed: $repo $branch $commit" --file $DEPLOY_LOG
  fi
done
