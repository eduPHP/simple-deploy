#!/usr/bin/env bash
set -euo pipefail

REPO="$1"      # e.g. git@github.com:eduPHP/ai-resume-optimizer.git
BRANCH="$2"    # e.g. main
COMMIT="$3"    # commit hash

# Extract app name from repo URL (strip .git, take last path component)
APP=$(basename -s .git "$REPO")
BASE_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && cd .. && pwd )"

source $BASE_DIR/.env
BASE="$DEPLOY_DIR/$APP"
RELEASES="$BASE/releases"
CURRENT="$BASE/current"
TIMESTAMP=$(date +%Y%m%d%H%M%S)
NEW_RELEASE="$RELEASES/$TIMESTAMP"

echo "==> Deploying $APP @ $COMMIT ($BRANCH) to $NEW_RELEASE"

mkdir -p "$RELEASES"

# Before cloning
if [ -L "$CURRENT" ]; then
  PREV_COMMIT=$(git -C "$CURRENT" rev-parse --short HEAD)
else
  PREV_COMMIT=""
fi

# 1. Clone repository at branch
git clone --branch "$BRANCH" "git@github.com:$REPO.git" "$NEW_RELEASE"
cd "$NEW_RELEASE"

# 2. Checkout exact commit
git checkout -q "$COMMIT"

if [ -n "$PREV_COMMIT" ]; then
  CHANGED=$(git diff --name-only "$COMMIT" "$PREV_COMMIT")
else
  CHANGED="all"
fi

## run project deployment steps here
if [ -d ".deploy" ]; then
  shopt -s nullglob
  RUN_SCRIPTS=(.deploy/*.run.sh)
  if [ ${#RUN_SCRIPTS[@]} -gt 0 ]; then
    echo "==> Running project scripts (.deploy/*.run.sh)"
    for SCRIPT in "${RUN_SCRIPTS[@]}"; do
      echo "==> Running $SCRIPT"
      # Source to preserve parent context (env + vars)
      . "$SCRIPT"
    done
  else
    echo "==> No project scripts found (.deploy/*.run.sh)"
  fi
  shopt -u nullglob
else
  echo "==> No .deploy directory found"
fi

$BASE_DIR/bin/cleanup "$RELEASES"

echo "==> Deploy complete. Now serving $NEW_RELEASE"
